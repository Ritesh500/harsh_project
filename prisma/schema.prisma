// Mekhas data model
// Run `npm run db:push` after editing, then `npm run db:seed` for samples.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String   @default("")
  // Price stored in cents to avoid floating-point rounding issues.
  priceCents     Int      @default(0)
  compareAtCents Int? // optional "was" price for showing a discount
  imageUrl       String?
  category       String?
  stock          Int      @default(0)
  comingSoon     Boolean  @default(false)
  featured       Boolean  @default(false)
  // Draft products are hidden from the storefront.
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published])
  @@index([comingSoon])
}
